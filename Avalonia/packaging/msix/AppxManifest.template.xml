<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:desktop="http://schemas.microsoft.com/appx/manifest/desktop/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap desktop rescap">
  <Identity
    Name="__PACKAGE_NAME__"
    Publisher="__PUBLISHER__"
    Version="__PACKAGE_VERSION__" />
  <Properties>
    <DisplayName>__DISPLAY_NAME__</DisplayName>
    <PublisherDisplayName>__PUBLISHER_DISPLAY_NAME__</PublisherDisplayName>
    <Description>Cross-platform tray app for managing a local GitHub Actions self-hosted runner.</Description>
    <Logo>Assets\AppIcon.png</Logo>
  </Properties>
  <Resources>
    <Resource Language="x-generate" />
  </Resources>
  <Dependencies>
    <TargetDeviceFamily
      Name="Windows.Desktop"
      MinVersion="10.0.19041.0"
      MaxVersionTested="10.0.22631.0" />
  </Dependencies>
  <Applications>
    <Application
      Id="GitRunnerManager"
      Executable="GitRunnerManager\GitRunnerManager.exe"
      EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="__DISPLAY_NAME__"
        Description="GitHub self-hosted runner manager"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\AppIcon.png"
        Square44x44Logo="Assets\AppIcon.png">
        <uap:DefaultTile
          Square310x310Logo="Assets\AppIcon.png"
          Wide310x150Logo="Assets\AppIcon.png"
          Square71x71Logo="Assets\AppIcon.png" />
      </uap:VisualElements>
      <Extensions>
        <desktop:Extension
          Category="windows.fullTrustProcess"
          Executable="GitRunnerManager\GitRunnerManager.exe" />
      </Extensions>
    </Application>
  </Applications>
  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
